{
  "name": "@planlux/desktop",
  "version": "1.0.1",
  "description": "Planlux Hale – kalkulator i CRM ofert hal stalowych",
  "author": "Planlux",
  "repository": {
    "type": "git",
    "url": "https://github.com/planlux/planlux-hale.git"
  },
  "main": "dist/electron/main.js",
  "scripts": {
    "build": "npm run build -w @planlux/shared && vite build && tsc && npm run copy:assets",
    "build:electron": "tsc",
    "dev:electron": "tsc --watch",
    "test": "vitest run electron/",
    "test:renderer": "vitest run --config vitest.renderer.config.ts",
    "test:all": "npm run test && npm run test:renderer",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:report": "playwright show-report",
    "test:electron": "vitest run electron/ --environment node",
    "test:watch": "vitest",
    "test:pdf": "electron . --test-pdf",
    "copy:assets": "node -e \"var fs=require('fs'),path=require('path');var s=path.join('assets');var t=path.join('dist','assets');if(fs.existsSync(s)){try{fs.mkdirSync(path.dirname(t),{recursive:true});fs.cpSync(s,t,{recursive:true});}catch(e){console.warn('Copy assets:',e.message);}}\"",
    "build:renderer": "vite build",
    "start": "electron .",
    "dev": "vite",
    "clean": "rimraf dist",
    "pdf:rebuild:test": "npm run clean && npm run build",
    "dist": "electron-builder --win nsis",
    "build:win": "npm run build && electron-builder --win",
    "dist:win": "cross-env CSC_IDENTITY_AUTO_DISCOVERY=false npm run build && cross-env CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --win --publish never --projectDir .",
    "rebuild": "electron-rebuild -f -w keytar"
  },
  "build": {
    "appId": "pl.planlux.hale",
    "productName": "Planlux Hale",
    "electronVersion": "28.3.3",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "build/icon.ico",
        "to": "icon.ico"
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico",
      "signAndEditExecutable": false
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  },
  "dependencies": {
    "@emotion/react": "^11.13.5",
    "@emotion/styled": "^11.13.5",
    "@fontsource/inter": "^5.2.8",
    "@mui/icons-material": "^7.3.8",
    "@mui/material": "^7.0.0",
    "@planlux/shared": "1.0.0",
    "@supabase/supabase-js": "^2.98.0",
    "better-sqlite3": "^9.2.2",
    "electron-updater": "^6.3.0",
    "keytar": "^7.9.0",
    "nodemailer": "^8.0.1",
    "pdfjs-dist": "^4.0.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "recharts": "^3.7.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/better-sqlite3": "^7.6.8",
    "@types/node": "^20.10.0",
    "@types/nodemailer": "^7.0.11",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.2.1",
    "@vitest/ui": "^3.2.0",
    "electron": "28.3.3",
    "electron-builder": "^26.8.1",
    "happy-dom": "^15.11.7",
    "jsdom": "^28.1.0",
    "playwright": "^1.49.0",
    "rimraf": "^5.0.0",
    "typescript": "^5.3.0",
    "vite": "^5.4.21",
    "vitest": "^3.2.0"
  }
}
