# Planlux Hale – przykładowe zmienne dla trybu deweloperskiego
#
# Skopiuj ten plik do:
#   - .env                  (katalog główny repozytorium) LUB
#   - packages/desktop/.env (jeśli wolisz trzymać env tylko dla aplikacji desktop)
#
# W produkcji (zbudowana aplikacja / CI) konfiguracja pochodzi ze zmiennych
# środowiskowych systemu / sekretów CI – tego pliku NIE używamy.

# -----------------------------------------------------------------------------
# Supabase – backend (Electron main / Node)
# -----------------------------------------------------------------------------

SUPABASE_URL=https://fxsqwmflnzdnalkhwnuz.supabase.co

# Anon key (JWT) – używany przez aplikację.
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImZ4c3F3bWZsbnpkbmFsa2h3bnV6Iiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzI1NzkwMDEsImV4cCI6MjA4ODE1NTAwMX0.BdbCNVYu-3DGxArVEAi3_-PtK-BO-XfSNFWcPtuSgzc

# Opcjonalny alias tego samego klucza (dla zgodności):
SUPABASE_PUBLISHABLE_KEY=sb_publishable_-uI4LEze8IwCUmgK-K6Jkg_bJEDB-wl

# -----------------------------------------------------------------------------
# Supabase – renderer (Vite, import.meta.env.VITE_*)
# -----------------------------------------------------------------------------

VITE_SUPABASE_URL=https://fxsqwmflnzdnalkhwnuz.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_-uI4LEze8IwCUmgK-K6Jkg_bJEDB-wl
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImZ4c3F3bWZsbnpkbmFsa2h3bnV6Iiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzI1NzkwMDEsImV4cCI6MjA4ODE1NTAwMX0.BdbCNVYu-3DGxArVEAi3_-PtK-BO-XfSNFWcPtuSgzc

# -----------------------------------------------------------------------------
# Konfiguracja aplikacji
# -----------------------------------------------------------------------------

# Timeout zapytań health-check dla backendu (ms).
ONLINE_TIMEOUT_MS=2000

# Czas życia sesji logowania (w godzinach).
SESSION_TTL_HOURS=12

# Dane pierwszego konta admina (seed przy init DB).
ADMIN_INITIAL_EMAIL=admin@planlux.pl
ADMIN_INITIAL_PASSWORD=

# Poziom logów:
#   - debug, info, warn, error
LOG_LEVEL=debug

# Opcjonalny alias poziomu logów (nadpisuje LOG_LEVEL, jeśli ustawiony).
# PLANLUX_LOG_LEVEL=debug

# -----------------------------------------------------------------------------
# URL-e opcjonalne
# -----------------------------------------------------------------------------

# Opcjonalny URL do aktualizacji / backendu, jeśli inny niż SUPABASE_URL.
# PLANLUX_UPDATES_URL=

# Zachowane dla zgodności w testach – w runtime preferowany jest SUPABASE_URL.
# PLANLUX_BACKEND_URL=

# -----------------------------------------------------------------------------
# SMTP (opcjonalnie – wysyłka e-mail przez zewnętrzny SMTP)
# -----------------------------------------------------------------------------

# PLANLUX_SMTP_HOST=
# PLANLUX_SMTP_PORT=587
# PLANLUX_SMTP_SECURE=true
# PLANLUX_SMTP_USER=
# PLANLUX_SMTP_PASS=
# PLANLUX_SMTP_FROM="Planlux Hale" <noreply@example.com>

# -----------------------------------------------------------------------------
# E2E / testy lokalne (opcjonalne)
# -----------------------------------------------------------------------------

# PLANLUX_E2E=1
# PLANLUX_E2E_DIR=./.e2e
# PLANLUX_E2E_TEMPLATE_DIR=./packages/desktop/assets/pdf-template/Planlux-PDF

# Dodatkowa diagnostyka cennika / wariantów.
# PLANLUX_VARIANTS_DEBUG=1

